rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function hasActiveSubscription() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.subscription.status == 'active';
    }

    // 1. User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'subscription.status', 'subscription.paypalSubscriptionId']);
    }

    // 2. 3D Roleplay Matrix Data (Read-only for all authenticated users)
    match /founderCategories/{docId} {
      allow read: if isAuthenticated();
    }
    
    match /industries/{docId} {
      allow read: if isAuthenticated();
    }
    
    match /clientRoles/{docId} {
      allow read: if isAuthenticated();
    }
    
    match /discPatterns/{docId} {
      allow read: if isAuthenticated();
    }

    // 3. Roleplay Sessions (Users only see their own)
    match /roleplaySessions/{sessionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Immutability for session history
    }

    // 4. Premium course content (if managed via Firestore)
    match /courses/{courseId}/lessons/{lessonId} {
      allow read: if isAuthenticated() && 
        (resource.data.isFree == true || hasActiveSubscription());
    }
    
    // 5. Payments (server-only writes)
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Cloud Functions/Admin SDK only
    }
    
    // 6. Subscriptions (server-only writes)
    match /subscriptions/{subId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Cloud Functions/Admin SDK only
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
