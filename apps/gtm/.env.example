# ── Core Infrastructure ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/soloframehub
REDIS_URL=redis://localhost:6379
# Set to "false" to disable Redis caching entirely
REDIS_ENABLED=true
# 32-byte hex key for encrypting sensitive fields (e.g. OAuth tokens)
ENCRYPTION_KEY=

# ── Authentication & Access Control ──────────────────────────────
# Set to "true" to bypass auth (local dev / demo mode only)
NEXT_PUBLIC_MOCK_AUTH=false
# Set to "true" to skip subscription checks (open beta)
OPEN_ACCESS=false
# Comma-separated emails allowed to sign up during beta
BETA_EMAILS=
# Comma-separated admin emails for admin dashboard access
ADMIN_EMAILS=
# Shared secret for internal admin API endpoints (facilitator, seed-demo, persona-respond)
ADMIN_API_SECRET=

# ── AI Providers ─────────────────────────────────────────────────
# Which provider to use: "openai", "anthropic", or "openrouter" (auto-detected if omitted)
AI_PROVIDER=
# At least one of these must be set
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# ── AI Model Overrides (optional) ────────────────────────────────
# Task-specific model selection. Falls back to provider defaults if unset.
# See lib/ai/models.ts for full list of tasks and defaults.
# AI_MODEL_COACHING=gpt-4o-mini
# AI_MODEL_ROLEPLAY=gpt-4o-mini
# AI_MODEL_ROLEPLAY_EVAL=gpt-4o-mini
# AI_MODEL_ASSESSMENT=gpt-4o-mini
# AI_MODEL_MINI_ASSESSMENT=gpt-4o-mini
# AI_MODEL_ICP_VALIDATION=gpt-4o-mini
# AI_MODEL_WEBSITE_ANALYSIS=gpt-4o-mini
# AI_MODEL_LINKEDIN_ANALYSIS=gpt-4o-mini
# AI_MODEL_RAG_EXTRACTION=gpt-4o-mini
# AI_MODEL_QUIZ_REFLECTION=gpt-4o-mini
# AI_MODEL_FACILITATOR=gpt-4o-mini
# AI_MODEL_PERSONA=gpt-4o-mini
# AI_MODEL_TTS=tts-1
# AI_MODEL_STT=whisper-1
# AI_MODEL_WORKSHOP=gpt-4o-mini
# AI_MODEL_DAILY_DIGEST=gpt-4o-mini

# Voice: TTS voice selection (alloy, echo, fable, onyx, nova, shimmer)
OPENAI_TTS_VOICE=alloy

# ── Object Storage (S3 / MinIO / R2) ────────────────────────────
# Primary S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=caa-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Public URL for serving uploaded files (optional)
S3_PUBLIC_URL=

# Aliases accepted by the storage layer (fallback order):
# S3_ACCESS_KEY, AWS_ACCESS_KEY_ID, R2_ACCESS_KEY_ID
# S3_SECRET_KEY, AWS_SECRET_ACCESS_KEY, R2_SECRET_ACCESS_KEY
# R2_ENDPOINT, R2_BUCKET, R2_PUBLIC_URL, AWS_REGION

# ── Payments (Polar.sh) ─────────────────────────────────────────
POLAR_ACCESS_TOKEN=
# Absolute URL users are redirected to after checkout
POLAR_SUCCESS_URL=https://...
# "sandbox" for testing, "production" for live
POLAR_MODE=sandbox
# Webhook secret for verifying Polar webhook signatures
POLAR_WEBHOOK_SECRET=

# Product IDs (client-side)
NEXT_PUBLIC_POLAR_MONTHLY_ID=
NEXT_PUBLIC_POLAR_ANNUAL_ID=
NEXT_PUBLIC_POLAR_BOOK_PRODUCT_ID=

# ── NodeBB Forum Integration ────────────────────────────────────
# Internal Docker network URL (Cloudflare blocks external calls)
NODEBB_URL=http://nodebb-container:4567/api/v3
# Master API token (requires _uid in every request)
NODEBB_API_KEY=
# Admin UID for master token auth (default: 1)
NODEBB_ADMIN_UID=1
# Parent category CID for dynamic pod categories
NODEBB_PODS_PARENT_CID=10
# Secret for verifying incoming NodeBB webhook payloads
NODEBB_WEBHOOK_SECRET=
# Public forum URL shown to users
NEXT_PUBLIC_FORUM_URL=https://ai-caa-forum.soloframehub.com

# ── Forum Bot UIDs ───────────────────────────────────────────────
# NodeBB user ID for the AI facilitator bot
FACILITATOR_BOT_UID=2
# Per-persona UIDs (optional, falls back to FACILITATOR_BOT_UID)
# PERSONA_ALEX_SKEPTIC_UID=3
# PERSONA_JORDAN_BUILDER_UID=4
# PERSONA_MORGAN_PERFECTIONIST_UID=5
# PERSONA_SAM_MENTOR_UID=6

# ── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Email Marketing (Listmonk) ──────────────────────────────────
LISTMONK_API_URL=http://172.20.0.3:9000
LISTMONK_API_USER=
LISTMONK_API_PASS=
LISTMONK_DEFAULT_LIST_ID=1
# Legacy aliases (accepted as fallbacks)
# LISTMONK_URL=
# LISTMONK_ADMIN_USERNAME=
# LISTMONK_ADMIN_PASSWORD=

# ── Analytics ────────────────────────────────────────────────────
# Google Analytics 4
GA4_MEASUREMENT_ID=G-SFYRWNQKZG
GA4_API_SECRET=
GA4_PROPERTY_ID=

# Umami (self-hosted)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=https://analytics.soloframehub.com

# Metabase dashboard URL
NEXT_PUBLIC_METABASE_URL=https://metabase.soloframehub.com

# ── Notion Integration ───────────────────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Badgr (Digital Badges) ──────────────────────────────────────
BADGR_BASE_URL=https://api.badgr.io
BADGR_ISSUER_ID=
BADGR_BADGE_EN_ID=
BADGR_BADGE_ES_ID=
BADGR_USERNAME=
BADGR_PASSWORD=

# ── Attio CRM ───────────────────────────────────────────────────
# Webhook secret for verifying incoming Attio webhooks
ATTIO_WEBHOOK_SECRET=

# ── n8n (Background Jobs) ───────────────────────────────────────
# Webhook URL that n8n calls for form submissions
N8N_FORM_WEBHOOK_URL=https://n8n.soloframehub.com/webhook/...

# ── Deployment (Dokploy) ────────────────────────────────────────
DOKPLOY_API_URL=http://46.202.88.248:3000/api
DEPLOY_API_KEY=

# ── App Metadata ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=soloframehub-v3
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Build-time Only ─────────────────────────────────────────────
# Set to "true" to enable webpack-bundle-analyzer
# ANALYZE=true
