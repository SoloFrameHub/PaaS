{
  "name": "solofame-platform",
  "version": "0.0.0",
  "private": true,
  "description": "SoloFrame Platform monorepo — engines, adapters, verticals, apps.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "depcruise": "depcruise --config .dependency-cruiser.cjs packages adapters verticals tools",
    "new-vertical": "pnpm --filter @platform/new-vertical exec new-vertical",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^20.14.10",
    "dependency-cruiser": "^16.10.0",
    "eslint": "^9.18.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
